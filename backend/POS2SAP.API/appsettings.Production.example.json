{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=HQ_FAMTIME;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=true;Connect Timeout=30;"
  },
  "AllowedOrigins": [
    "http://localhost:8080",
    "http://127.0.0.1:8080",
    "http://YOUR_SERVER:8080"
  ],
  "Jwt": {
    "Secret": "REPLACE-WITH-RANDOM-32-PLUS-CHARACTERS-SECRET",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "Issuer": "POS2SAP",
    "Audience": "POS2SAPUsers"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*:/api/*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "5m",
        "Limit": 5
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
