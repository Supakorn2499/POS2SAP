{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend (dotnet)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/backend/POS2SAP.API/bin/Debug/net8.0/POS2SAP.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/POS2SAP.API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5163"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    }
  ]
}
